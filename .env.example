GUGO_UPLOAD_PASSWORD=change-this-upload-password
GUGO_ADMIN_PASSWORD=change-this-admin-password
GUGO_SESSION_SECRET=change-this-long-random-secret
# Local dev can use ./storage. Production should use an absolute persistent path,
# for example /var/lib/gugogallery/storage.
GUGO_STORAGE_DIR=./storage
PORT=8788
